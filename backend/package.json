{
  "name": "university-assistant-backend",
  "version": "2.0.0",
  "description": "AI-Driven University Assistant — 4hr Complete Hackathon",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit --testTimeout=30000",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "build": "echo 'Build OK'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.5",
    "openai": "^4.28.0",
    "xlsx": "^0.18.5",
    "pdf-parse": "^1.1.1",
    "mysql2": "^3.9.1",
    "vectra": "^0.6.0",
    "winston": "^3.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js",
      "db/**/*.js"
    ],
    "coverageThreshold": { "global": { "lines": 50 } }
  }
}
